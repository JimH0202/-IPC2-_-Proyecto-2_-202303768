@page
@model IndexModel
@{
    ViewData["Title"] = "Sistema de Drones USAC";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Drones USAC</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 800px;
            width: 100%;
            padding: 60px 40px;
            text-align: center;
        }

        .header {
            margin-bottom: 30px;
        }

        .logo {
            font-size: 48px;
            margin-bottom: 20px;
        }

        h1 {
            color: #333;
            font-size: 2.5em;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: #666;
            font-size: 1.1em;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        .features {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 40px;
            text-align: left;
        }

        .features h3 {
            color: #667eea;
            margin-bottom: 20px;
            font-size: 1.3em;
        }

        .features ul {
            list-style: none;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .features li {
            color: #555;
            padding: 10px;
            display: flex;
            align-items: center;
        }

        .features li:before {
            content: "✓ ";
            color: #667eea;
            font-weight: bold;
            margin-right: 10px;
            font-size: 1.2em;
        }

        .cta-button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 50px;
            font-size: 1.1em;
            border-radius: 50px;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.4);
        }

        .cta-button:active {
            transform: translateY(-1px);
        }

        @@media (max-width: 600px) {
            .container {
                padding: 40px 20px;
            }

            h1 {
                font-size: 1.8em;
            }

            .features ul {
                grid-template-columns: 1fr;
            }

            .cta-button {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">🚁</div>
            <h1>Sistema de Gestión de Drones</h1>
            <p class="subtitle">
                Gestión de drones para transmisión de mensajes encriptados usando listas enlazadas
            </p>
        </div>

        <div class="features">
            <h3>Características del Sistema</h3>
            <ul>
                <li>Listas Enlazadas (TDAs) en C#</li>
                <li>Lectura de archivos XML</li>
                <li>Generación de Gráficos con Graphviz</li>
                <li>Simulación de Drones Paralelos</li>
                <li>Decodificación de Mensajes</li>
                <li>Exportación de XML Optimizado</li>
            </ul>
        </div>

        <button class="cta-button" onclick="redirectToSystem()">
            Acceder al Sistema de Drones
        </button>
    </div>

    <script>
        function redirectToSystem() {
            window.location.href = '/Sistema';
        }
    </script>
</body>
</html>
